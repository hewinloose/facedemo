{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "facedemo-rust",
  "version": "0.1.0",
  "identifier": "com.facedemo.rust",
  "build": {
    "beforeDevCommand": "dx serve --platform web -- --features tauri-backend",
    "beforeBuildCommand": "dx build --release --platform web -- --features tauri-backend",
    "devUrl": "http://127.0.0.1:8080",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "facedemo-rust",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.ico"]
  }
}
